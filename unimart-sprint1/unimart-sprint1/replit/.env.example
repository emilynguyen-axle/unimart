# ============================================================
# UniMart Sprint 1 — Replit Environment Variables
# Copy this to .env and fill in real values
# ============================================================

# Supabase
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY
SUPABASE_ANON_KEY=YOUR_ANON_KEY

# App
PORT=3001
LOVABLE_URL=https://YOUR_LOVABLE_APP.lovable.app

# n8n webhook (set after n8n is deployed)
N8N_WEBHOOK_VELOCITY=https://YOUR_N8N_INSTANCE/webhook/sprint-velocity
N8N_WEBHOOK_FINDINGS=https://YOUR_N8N_INSTANCE/webhook/workshop-findings
