# ================================================================
# UniMart Sprint 1 — Environment Variables
# Copy to .env and fill in your values
# ================================================================

# ── Supabase ─────────────────────────────────────────────────
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# ── Lovable (frontend env vars — prefix with VITE_) ──────────
VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here
VITE_API_BASE_URL=https://your-replit-app.replit.app

# ── Replit backend ────────────────────────────────────────────
PORT=3000
LOVABLE_APP_URL=https://your-lovable-app.lovable.app

# ── n8n ──────────────────────────────────────────────────────
# Set these in n8n credentials UI — not in .env
# SLACK_BOT_TOKEN=xoxb-...
# SUPABASE_POSTGRES_HOST=db.YOUR_PROJECT.supabase.co
# SUPABASE_POSTGRES_PORT=5432
# SUPABASE_POSTGRES_DB=postgres
# SUPABASE_POSTGRES_USER=postgres
# SUPABASE_POSTGRES_PASSWORD=your_db_password
